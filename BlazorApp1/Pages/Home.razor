@page "/"
@inject IJSRuntime JS

@if (currentStep == 0)
{
    <div style="text-align: center; margin-top: 50px;">
        <h1>Здравей, не съм много добър с думите, затова реших да използвам знанията си, за да ти кажа какво мисля за теб под формата на тази онлайн платформа.</h1>
        <button @onclick="() => currentStep = 1" style="margin-top: 20px;">Продължи</button>
    </div>
}
else if (currentStep == 1)
{
    <div style="text-align: center; margin-top: 50px;">
        <h1>Искам да ти задам един въпрос...</h1>
        <button @onclick="() => currentStep = 2" style="margin-top: 20px;">Продължи</button>
    </div>
}
else if (currentStep == 2)
{
    <div style="text-align: center; margin-top: 50px;">
        <p style="font-size: 24px;">Би ли излязла с мен на среща?</p>
        <div style="display: flex; justify-content: center; gap: 20px; margin-top: 50px;">
            <button @onclick="() => currentStep = 3">Да</button>
            <button @onclick="SelectRejection">Не</button>
        </div>
    </div>
}
else if (currentStep == 3)
{
    <div style="text-align: center; margin-top: 50px;">
        <h1>Какво би избрала за хапване?</h1>
        <input @bind="invitation.food" placeholder="напиши своя избор тук..." style="padding: 10px; width: 300px;" />
        <div style="margin-top: 20px;">
            <button @onclick="() => currentStep = 4">Готово</button>
        </div>
    </div>
}
else if (currentStep == 4)
{
    <div style="text-align: center; margin-top: 50px;">
        <h1>Къде би искала да отидем?</h1>
        <input @bind="invitation.location" placeholder="напиши своя избор тук..." style="padding: 10px; width: 300px; display: block; margin: 10px auto;" />
        
        <div style="display: flex; flex-direction: column; align-items: center; gap: 10px; margin-top: 20px;">
            <button @onclick='() => {showOptions = true;}'>Идеи за място</button>
            @if(showOptions != false)
            {
                <button @onclick='() => { invitation.location = "Парк паметник"; }' style="padding: 10px; border:  thick">Парк паметник на българо-съветската дружба</button>
                <button @onclick='() => { invitation.location = "Градската градина"; }' style="padding: 10px;">Градската градина</button>
                <button @onclick='() => { invitation.location = "Ледената пързалка"; }' style="padding: 10px;">Ледената пързалка</button>
            }
              <button @onclick='() => {currentStep = 5;}'>Потвърди</button>
        </div>
    </div>
}
else if (currentStep == 5)
{
    <div style="text-align: center; margin-top: 50px;">
        <h1>Кога би искала да се видим?</h1>
        <input type="datetime-local" @bind="invitation.date" style="padding: 10px; width: 300px;" />
        
        <div style="margin-top: 20px;">
            <button @onclick="() => currentStep = 6">Готово</button>
            @if (invitation.date < DateTime.Now)
            {
                <p style="color: red; margin-top: 10px;">Моля, избери бъдеща дата и час.</p>
            }
        </div>
    </div>
}
else if (currentStep == 6)
{
    <div style="text-align: center; margin-top: 50px;">       
            <h1>Благодаря ти! Ще се постарая да си прекараш страхотно!</h1>
            <p>Избра да хапнем: <b>@invitation.food</b></p>
            <p>Избра да отидем: <b>@invitation.location</b></p>
            <p>Избра дата и час: <b>@invitation.date.ToString("dd.MM.yyyy HH:mm")</b></p>
            <button @onclick="SendEMail" style="margin-top: 20px;">Изпрати отговорите</button>        
    </div>
}
else if (currentStep == 7)
{
    <div style="text-align: center; margin-top: 50px;">
        <h1>Всичко е изпратено! Благодаря ти! ✨</h1>
    </div>
} else if(currentStep == 8)
{
    <div style="text-align: center; margin-top: 50px;">
        <h1>Благодаря отделеното време.</h1>
    </div>
}


@code {
    int currentStep = 0;

    public class InvitationModel
    {
        public DateTime date { get; set; } = DateTime.Now.AddDays(1);
        public string food { get; set; } = "";
        public string location { get; set; } = "";
        public bool selectRejection { get; set; } = false;
    }

    public InvitationModel invitation = new InvitationModel();

    public void SelectRejection()
    {
        invitation.selectRejection = true;
        currentStep = 6;
    }
    bool showOptions = false;

    public async Task SendEMail()
    {
        string emailContent;
        if (invitation.selectRejection)
        {
            emailContent = "За съжаление, тя отказа поканата.";
        }
        else
        {
            emailContent = $"Приета среща! Храна: {invitation.food}, Място: {invitation.location}, Дата: {invitation.date:dd.MM.yyyy HH:mm}";
        }

        // Извикваме JavaScript функцията "sendEmail", която дефинирахме в index.html
        await JS.InvokeVoidAsync("sendEmail", emailContent);
        
        currentStep = 7;
    }
}